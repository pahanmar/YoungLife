# Копируйте в .env и при необходимости измените значения.
# При запуске через Docker переменные для БД и сида заданы в docker-compose.yml;
# здесь нужны в основном для локального запуска backend без Docker.

# Подключение к PostgreSQL
# Локально: postgresql://USER:PASSWORD@localhost:5432/younglife_db
# В Docker: задаётся в docker-compose (postgres:5432)
DATABASE_URL=postgresql://younglife:younglifepass@localhost:5432/younglife_db

# Секрет для JWT (обязательно сменить в продакшене)
JWT_SECRET=change_this_secret

# Админ при первом сиде (если не задано — используются значения из docker-compose / дефолты)
# SEED_ADMIN_EMAIL=admin@younglife.local
# SEED_ADMIN_PWD=admin123

# Фронт для CORS
FRONTEND_URL=http://localhost:5173
