datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           Int      @id @default(autoincrement())
  name         String?
  email        String   @unique
  phone        String?
  passwordHash String
  role         String   @default("user")
  createdAt    DateTime @default(now())
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  revoked   Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Content {
  id        Int      @id @default(autoincrement())
  title     String
  body      String
  roles     String[]  // роли, которым доступен контент, пустой = публичный
  createdAt DateTime @default(now())
}

model RoutePermission {
  id           Int     @id @default(autoincrement())
  path         String  @unique
  mode         String  @default("all")  // all | allow | deny
  roles        String[]
  hideFromNav  Boolean @default(false)  // скрыть пункт меню для ролей без доступа
}

model Book {
  id            Int      @id @default(autoincrement())
  title         String
  author        String?
  description   String?
  coverPath     String?  // путь к обложке в uploads
  bookFilePath  String   // путь к файлу книги в uploads
  downloadMode  String   @default("inherit")  // inherit | all | allow | deny
  downloadRoles String[] @default([])         // роли для allow/deny (при inherit не используются)
  createdAt     DateTime @default(now())
}

model DownloadDocument {
  id        Int      @id @default(autoincrement())
  title     String   // название для кнопки
  iconPath  String?  // путь к иконке в uploads/documents
  filePath  String   // путь к файлу в uploads/documents
  sortOrder Int      @default(0) // порядок вывода
  createdAt DateTime @default(now())
}